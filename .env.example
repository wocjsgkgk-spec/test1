# 선택: DB 접속 URL. 설정 시 TODO_DB_PATH보다 우선한다.
# SQLite 예시: sqlite:///./todos.db
# PostgreSQL 예시: postgresql+psycopg://user:password@localhost:5432/taskflow
DATABASE_URL=

# 필수: JWT HS256 서명용 충분히 긴 무작위 비밀키
JWT_SECRET=

# 선택: OpenAI API 인증 키(AI 추천 기능 사용 시 필요)
OPENAI_API_KEY=

# 레거시 SQLite 경로(기본값: 프로젝트 루트의 todos.db)
TODO_DB_PATH=todos.db
